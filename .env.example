# 高德地图API配置
AMAP_API_KEY=your_amap_api_key_here
AMAP_SECURITY_KEY=your_amap_security_key_here

# JWT配置
JWT_SECRET=yanxiaomap_jwt_secret_key_2026_change_this_in_production
JWT_EXPIRATION=86400000

# 数据库配置（Docker Compose中已配置，可在此覆盖）
DATABASE_URL=jdbc:mysql://localhost:3306/yanxiaomap?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai
DATABASE_USERNAME=root
DATABASE_PASSWORD=root

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379

# Spring配置
SPRING_PROFILES_ACTIVE=docker